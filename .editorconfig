root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ----------------------------
# Global C# rules (common)
# ----------------------------
[*.cs]
indent_style = space
indent_size = 4

# Usings
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true

# Accessibility
dotnet_style_require_accessibility_modifiers = for_non_interface_members:suggestion

# var preferences - use var everywhere (IDE0007)
csharp_style_var_for_built_in_types = true:warning
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere = true:warning

# Enable IDE0007 fixer (use 'var' instead of explicit type)
dotnet_diagnostic.IDE0007.severity = warning

# Naming rules
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_style.interface_prefix.required_prefix = I
dotnet_naming_style.interface_prefix.capitalization = pascal_case
dotnet_naming_rule.interfaces_should_have_prefix.symbols = interfaces
dotnet_naming_rule.interfaces_should_have_prefix.style = interface_prefix
dotnet_naming_rule.interfaces_should_have_prefix.severity = warning

dotnet_naming_symbols.public_members.applicable_kinds = property, method, event, field
dotnet_naming_symbols.public_members.applicable_accessibilities = public, internal, protected, protected_internal
dotnet_naming_style.pascal.capitalization = pascal_case
dotnet_naming_rule.public_members_pascal.symbols = public_members
dotnet_naming_rule.public_members_pascal.style = pascal
dotnet_naming_rule.public_members_pascal.severity = warning

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.private_field_underscore.required_prefix = _
dotnet_naming_style.private_field_underscore.capitalization = camel_case
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = private_field_underscore
dotnet_naming_rule.private_fields_underscore.severity = warning

# ----------------------------
# Namespace declarations (YOUR RULES)
# Put .editorconfig in repo root; these patterns match anywhere.
# ----------------------------

# Default for all C# files
[*.cs]
csharp_style_namespace_declarations = file_scoped:warning

# Braces - ALWAYS required
csharp_prefer_braces = true:error

# Expression-bodied members - arrow on same line, body on next line
csharp_style_expression_bodied_methods = true:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_operators = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion

# New line preferences for expression bodies
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# Line wrapping
max_line_length = 140

# Method arguments - keep on single line if fits within max_line_length
csharp_wrap_arguments = chop_if_long
csharp_wrap_parameters = chop_if_long
csharp_keep_existing_arrangement = true

# Override for protocol folders (more specific => wins)
[**/Gladiators.Common.Protocol/**/*.cs]
csharp_style_namespace_declarations = block_scoped:warning

[**/Protocol/**/*.cs]
csharp_style_namespace_declarations = block_scoped:warning
